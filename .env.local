# 1. Copy this file and rename it to .env.local
# 2. Update the environment variables below.

# REQUIRED SETTINGS
# If you are using LiveKit Cloud, the API key and secret can be generated from the Cloud Dashboard.
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=
# URL pointing to the LiveKit server. (example: `wss://my-livekit-project.livekit.cloud`)
LIVEKIT_URL=

# OPTIONAL SETTINGS

# Recording
# S3_KEY_ID=
# S3_KEY_SECRET=
# S3_ENDPOINT=
# S3_BUCKET=
# S3_REGION=

# PUBLIC
# Uncomment settings menu when using a LiveKit Cloud, it'll enable Krisp noise filters.
# NEXT_PUBLIC_SHOW_SETTINGS_MENU=true
# NEXT_PUBLIC_LK_RECORD_ENDPOINT=/api/record

# Optional, to pipe logs to datadog
# NEXT_PUBLIC_DATADOG_CLIENT_TOKEN=client-token
# NEXT_PUBLIC_DATADOG_SITE=datadog-site

# Optional, for live captions (Deepgram)
# NEXT_PUBLIC_DEEPGRAM_API_KEY=
# DEEPGRAM_API_KEY=

# Optional, Gemini (translation + TTS)
# GEMINI_API_KEY=
# GEMINI_MODEL_ID=gemini-2.5-flash-native-audio-preview-12-2025
# GEMINI_AUDIO_MODEL=gemini-2.5-flash-preview-tts
# GEMINI_TTS_VOICE_NAME=Kore

# Optional, Cartesia (TTS)
# CARTESIA_API_KEY=
# CARTESIA_MODEL_ID=sonic-3
# CARTESIA_VOICE_ID=

# Optional, for in-app agent (Ollama Cloud)
# OLLAMA_API_KEY=
# OLLAMA_BASE_URL=https://ollama.com
# OLLAMA_MODEL=gpt-oss:120b

# Optional, Google OAuth via Supabase (Tools > Google Services)
# Configure the Google provider in Supabase Auth.
NEXT_PUBLIC_SUPABASE_URL=https://crynxtqmltbcpwscxoda.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_DEFAULT_KEY=sb_publishable_-A7Q26SEflqesOHfzOCz5A_15no1EU-
